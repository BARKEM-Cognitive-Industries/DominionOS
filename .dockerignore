# Keep the Docker build context small and the layer cache warm.
# Build artefacts and disk images are regenerated inside the container.

# Rust build output (large; rebuilt in-container)
target/
**/target/

# Produced disk images and data disks (regenerated by the boot builder)
*.img

# Version control / IDE
.git/
.github/
.claude/

# Logs and machine-readable run output.
# NOTE: do NOT ignore *.json globally — the kernel's custom target specs
# (kernel/x86_64-dominion.json, kernel/x86_64-dominion-fma.json) are required to
# build. We exclude only the known result/log JSON files at the repo root.
*.log
/build.json
/clippy.json
/bench-results.json
/validate-results-*.json
kernel/build.json
kernel/clippy.json
kernel/clippy_all.json
*.ppm

# Large media / screenshots
*.mp4
*.png

# Editor noise
*.swp
