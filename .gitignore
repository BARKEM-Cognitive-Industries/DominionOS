# Secrets / local environment (never commit real keys; use *.env.example templates)
.env
*.env
**/.env
!*.env.example
!**/*.env.example

# Rust build output
target/
**/target/

# Produced disk images and data disks (regenerated by the boot builder)
*.img
*.img.bios

# Logs and machine-readable run output
*.log
*.err
*.watch.err
/build.json
/clippy.json
/bench-results.json
/validate-results-*.json
**/clippy.json
**/sizes.txt
kernel/build.json
kernel/clippy_all.json
*.ppm

# Boot/test output (text format)
/bootlog*.txt
/build-errors.txt
/usb-build-manifest.json

# Dev-only scripts and generated code dumps
/combined_code.md
/consolidate_code.py

# Audit session data
.audit/

# Agent communication files (Claude internal)
AGENT_COMMUNICATION_FILE.md

# Large media / screenshots
*.mp4
*.png
desktop.ppm

# Compiled probes / debug symbols
*.exe
*.pdb

# Editor noise
*.swp

# Python caches
__pycache__/
*.pyc

# Claude session state
.claude/

# Archived/draft documentation (not part of the release)
docs/_archive/
docs/_archive_2/

models/